{{ template "layout" . }}

{{ define "title" }}Page Not Found{{ end }}

{{ define "content" }}
  <div
    class="flex min-h-screen flex-col items-center justify-center text-white bg-elderberry"
  >
    <h1 class="text-6xl font-bold font-kalam">404</h1>
    <p class="mt-4 text-xl">Page not found.</p>
    <a href="/" class="mt-8 underline">Go home</a>
  </div>
{{ end }}
