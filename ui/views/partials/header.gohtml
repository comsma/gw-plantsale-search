{{ define "header" }}
  <header class="bg-elderberry sticky text-white">
    <div class="max-w-6xl mx-auto px-4 py-4">
      <div class="flex items-center gap-4 mb-3">
        <img
          src="/static/images/Wild-Ones-Chapter-Logo.svg"
          alt="Wild Ones Gibson Woods"
          class="h-24 w-auto shrink-0"
        />
        <div class="flex-1">
          <h1
            class="font-kalam text-[clamp(1.4rem,3.5vw,2rem)] leading-[1.15] m-0"
          >
            What Should I Plant Here?
          </h1>
          <p class="mt-1 mb-0 text-[0.85rem] text-white/80">
            Wild Ones Gibson Woods &bull; Native Plant Sale &bull; May 2, 2026
          </p>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex lg:gap-x-4 gap-y-2 border-t border-white/20 pt-3">
        <a href="/" class="btn btn-ghost"> Plant Quiz </a>
        <a href="/plants" class="btn btn-ghost"> Browse Plants </a>
        <a href="/favorites" class="btn btn-ghost">
          <svg
            class="w-4 h-4"
            viewBox="0 0 352 290"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill="currentColor"
